root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4

[*.md]
charset = utf-8
end_of_line = crlf
trim_trailing_whitespace = false

[*.env*]
charset = utf-8
end_of_line = crlf
trim_trailing_whitespace = false
